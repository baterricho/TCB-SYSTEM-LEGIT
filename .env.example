SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DB_NAME=tcb_backend
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Use a base64 encoded 32-byte key for production, for example generated by:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
MASTER_KEY=replace-with-base64-encoded-32-byte-master-key

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace@example.com
EMAIL_HOST_PASSWORD=replace-with-email-password
DEFAULT_FROM_EMAIL=The Creator's Bulwark <noreply@example.com>

# Optional IPOPHL email parser controls.
IPOPHL_ALLOWED_DOMAINS=ipophil.gov.ph,ipophl.gov.ph
IPOPHL_ALLOWED_SENDERS=
