# Django
SECRET_KEY=                        # Required. Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5505,http://127.0.0.1:5505

# Database (PostgreSQL / Supabase)
TCB_USE_SQLITE=False
DB_NAME=                           # Required
DB_USER=                           # Required
DB_PASSWORD=                       # Required. Min 32 characters, fully random
DB_HOST=                           # Required
DB_PORT=5432

# Encryption
MASTER_KEY=                        # Required. Generate: python -c "import secrets; print(secrets.token_hex(32))"

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=The Creator's Bulwark <noreply@example.com>

# Optional IPOPHL email parser controls.
IPOPHL_ALLOWED_DOMAINS=ipophil.gov.ph,ipophl.gov.ph
IPOPHL_ALLOWED_SENDERS=

# Feature Flags
TCB_PRINT_OTP_TO_CONSOLE=False     # Set True only in local dev
